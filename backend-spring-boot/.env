# Environment Variables Configuration
# DO NOT commit .env to version control

# JWT Configuration
# Minimum 32 characters required for security
JWT_SECRET=ethioloadai-spring-boot-jwt-secret-key-256-bits-secure

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5433/ethioloadai_spring
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=secret

# Server Configuration
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# JWT Expiration (optional - defaults to 15 minutes)
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# AI Engine Configuration (optional)
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_ENABLED=true
